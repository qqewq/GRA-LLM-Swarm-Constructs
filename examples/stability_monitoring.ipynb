   "source": [
    "# Мониторинг когнитивной стабильности LLM через GRA-метрики\n",
    "\n",
    "Этот ноутбук демонстрирует вычисление Φ, ΔΦ, Δ²Φ на примере GPT-2 и произвольном промпте."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install transformers torch\n",
    "import torch\n",
    "from transformers import GPT2LMHeadModel, GPT2Tokenizer\n",
    "import matplotlib.pyplot as plt\n",
    "import sys\n",
    "sys.path.append('..')\n",
    "from gra_llm.integrations import GRAWrapper\n",
    "\n",
    "model_name = 'gpt2'\n",
    "model = GPT2LMHeadModel.from_pretrained(model_name, output_hidden_states=True, output_attentions=True)\n",
    "tokenizer = GPT2Tokenizer.from_pretrained(model_name)\n",
    "cfg = {'foam_threshold': 0.1, 'apply_nullification': False}\n",
    "wrapper = GRAWrapper(model, cfg)\n",
    "\n",
    "prompt = "The capital of France is"\n",
    "inputs = tokenizer(prompt, return_tensors='pt')\n",
    "outputs, foam_vals = wrapper.forward_with_gra(**inputs)\n",
    "\n",
    "# foam_vals — тензоры, переведём в числа\n",
    "foam_list = [v.item() for v in foam_vals]\n",
    "layers = list(range(len(foam_list)))\n",
    "\n",
    "# Вычисляем производные\n",
    "d_foam = [foam_list[i+1] - foam_list[i] for i in range(len(foam_list)-1)]\n",
    "d2_foam = [foam_list[i+1] - 2*foam_list[i] + foam_list[i-1] for i in range(1, len(foam_list)-1)]\n",
    "\n",
    "# Визуализация\n",
    "fig, axs = plt.subplots(3, 1, figsize=(10, 12))\n",
    "axs[0].plot(layers, foam_list, marker='o')\n",
    "axs[0].set_title('Φ per layer')\n",
    "axs[0].set_xlabel('Layer')\n",
    "axs[0].set_ylabel('Foam')\n",
    "\n",
    "axs[1].plot(layers[:-1], d_foam, marker='x', color='orange')\n",
    "axs[1].axhline(0, linestyle='--', color='gray')\n",
    "axs[1].set_title('ΔΦ (first difference)')\n",
    "axs[1].set_xlabel('Layer')\n",
    "axs[1].set_ylabel('ΔΦ')\n",
    "\n",
    "axs[2].plot(layers[1:-1], d2_foam, marker='s', color='green')\n",
    "axs[2].axhline(0, linestyle='--', color='gray')\n",
    "axs[2].set_title('Δ²Φ (second difference)')\n",
    "axs[2].set_xlabel('Layer')\n",
    "axs[2].set_ylabel('Δ²Φ')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Интерпретация:\n",
    "\n",
    "- Если Φ не монотонно убывает, есть слои с повышенной пеной — потенциальные источники противоречий.\n",
    "- Отрицательные Δ²Φ указывают на локальную нестабильность.\n",
    "- После применения GRA‑обнуления (T_l) графики должны стать близки к критерию Φ≈0, ΔΦ≈0, Δ²Φ>0."
   ]
  }
